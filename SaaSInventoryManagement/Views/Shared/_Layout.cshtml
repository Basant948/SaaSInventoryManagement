<!DOCTYPE html>
@using Microsoft.EntityFrameworkCore
@using SaaSInventoryManagement.Services.Interfaces_
@inject ApplicationDbContext Db
@inject ITenantProvider TenantProvider
@{
    var tenantName = "Platform";
    if (User.Identity?.IsAuthenticated == true)
    {
        if (TenantProvider.IsSuperAdmin)
        {
            tenantName = "Super Admin";
        }
        else if (TenantProvider.TenantId is int tid)
        {
            tenantName = (await Db.Tenants.Where(t => t.Id == tid).Select(t => t.Name).FirstOrDefaultAsync()) ?? "Workspace";
        }
    }
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InventoryWithAI</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@6.5.2/css/all.min.css" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
                <div class="brand-text">
                    <div class="brand-title">InventoryWithAI</div>
                    <div class="brand-subtitle">@tenantName</div>
                </div>
            </div>

            <nav class="sidebar-nav">
                @await Component.InvokeAsync("Navbar")
            </nav>

            <div class="sidebar-footer">
                <partial name="_LoginPartial" />
            </div>
        </aside>

        <div class="main-area">
            <header class="topbar">
                <button class="sidebar-toggle d-lg-none" type="button" onclick="document.querySelector('.app-shell').classList.toggle('sidebar-open')">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="topbar-title">@ViewData["Title"]</div>
            </header>

            <main role="main" class="content">
                @RenderBody()
            </main>

            <footer class="content-footer text-muted">
                &copy; @DateTime.Now.Year - InventoryWithAI
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
