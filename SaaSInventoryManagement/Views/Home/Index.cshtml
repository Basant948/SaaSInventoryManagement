@using SaaSInventoryManagement.ViewModels.Navigation
@using Microsoft.EntityFrameworkCore
@model List<NavGroupDto>
@inject ApplicationDbContext Db
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h1 class="display-6">Welcome back, @User.Identity!.Name</h1>
    <p class="text-muted">
        @(User.IsInRole("SuperAdmin") ? "Platform overview." : "Here's everything your account has access to.")
    </p>
</div>

@if (User.IsInRole("SuperAdmin"))
{
    var tenantCount = await Db.Tenants.CountAsync();
    var activeTenantCount = await Db.Tenants.CountAsync(t => t.IsActive);

    <div class="row g-3">
        <div class="col-6 col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="fa-solid fa-building fa-2x mb-2 text-primary"></i>
                    <div class="fs-4 fw-bold">@tenantCount</div>
                    <div class="text-muted small">Total tenants</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="fa-solid fa-circle-check fa-2x mb-2 text-success"></i>
                    <div class="fs-4 fw-bold">@activeTenantCount</div>
                    <div class="text-muted small">Active tenants</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a class="text-decoration-none" asp-controller="TenantManagement" asp-action="Index">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fa-solid fa-list fa-2x mb-2 text-secondary"></i>
                        <div class="fw-semibold">Manage Tenants</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a class="text-decoration-none" asp-controller="TenantManagement" asp-action="Create">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fa-solid fa-plus fa-2x mb-2 text-secondary"></i>
                        <div class="fw-semibold">New Tenant</div>
                    </div>
                </div>
            </a>
        </div>
    </div>
}
else
{
    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            No features have been granted to your account yet. Contact your tenant admin.
        </div>
    }

    @foreach (var group in Model)
    {
        <h5 class="mt-4 mb-3">@group.GroupName</h5>
        <div class="row g-3">
            @foreach (var item in group.Items)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <a class="text-decoration-none" asp-controller="Home" asp-action="Feature" asp-route-key="@item.Key">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body text-center">
                                <i class="@item.IconClass fa-2x mb-2 text-primary"></i>
                                <div class="fw-semibold">@item.DisplayName</div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
}