@using SaaSInventoryManagement.ViewModels.TenantManagement
@model CreateTenantViewModel
@{
    ViewData["Title"] = "New Tenant";
}

<h1 class="h3 mb-4">New Tenant</h1>

<div class="card shadow-sm" style="max-width: 560px;">
    <div class="card-body">
        <form asp-controller="TenantManagement" asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h6 class="text-muted text-uppercase small mb-3">Tenant</h6>

            <div class="form-group mb-3">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" autofocus />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Slug"></label>
                <input asp-for="Slug" class="form-control" placeholder="e.g. acme-corp" />
                <span asp-validation-for="Slug" class="text-danger"></span>
            </div>

            <h6 class="text-muted text-uppercase small mb-3">Initial Tenant Admin</h6>

            <div class="row">
                <div class="form-group mb-3 col-md-6">
                    <label asp-for="AdminFirstName"></label>
                    <input asp-for="AdminFirstName" class="form-control" />
                    <span asp-validation-for="AdminFirstName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3 col-md-6">
                    <label asp-for="AdminLastName"></label>
                    <input asp-for="AdminLastName" class="form-control" />
                    <span asp-validation-for="AdminLastName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AdminEmail"></label>
                <input asp-for="AdminEmail" class="form-control" />
                <span asp-validation-for="AdminEmail" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="AdminPassword"></label>
                <input asp-for="AdminPassword" class="form-control" />
                <span asp-validation-for="AdminPassword" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Tenant</button>
                <a class="btn btn-outline-secondary" asp-controller="TenantManagement" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
